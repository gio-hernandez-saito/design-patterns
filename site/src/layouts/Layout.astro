---
import '../styles/global.css';
import { patterns, categories } from '../data/patterns';

interface Props {
  title: string;
  activePattern?: string;
}

const { title, activePattern } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Design Patterns</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="header">
    <a href={base} class="logo">
      <span class="logo-icon">◆</span>
      Design Patterns
    </a>
    <span class="header-sub">GoF 23 · TypeScript + React / Vue / Svelte</span>
  </header>

  <div class="app">
    <nav class="sidebar">
      {categories.map(cat => (
        <div class="sidebar-group">
          <h3 class="sidebar-category" style={`--cat-color: ${cat.color}`}>
            {cat.name}
            <span class="sidebar-category-ko">{cat.nameKo}</span>
          </h3>
          <ul>
            {patterns.filter(p => p.category === cat.id).map(p => (
              <li>
                <a
                  href={`${base}${p.category}/${p.slug}/`}
                  class:list={['sidebar-link', { active: activePattern === p.slug }]}
                  style={`--cat-color: ${cat.color}`}
                >
                  {p.name}
                  {p.frameworks.length === 0 && <span class="ts-only">TS</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>

    <main class="content">
      <slot />
    </main>
  </div>
</body>
</html>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    padding: 0 1.5rem;
    gap: 1rem;
    z-index: 100;
  }

  .logo {
    font-weight: 700;
    font-size: 1.1rem;
    color: #f1f5f9;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo:hover { color: var(--color-accent); }

  .logo-icon {
    color: var(--color-accent);
    font-size: 1.2rem;
  }

  .header-sub {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .app {
    display: flex;
    padding-top: var(--header-height);
    min-height: 100vh;
  }

  .sidebar {
    position: fixed;
    top: var(--header-height);
    left: 0;
    bottom: 0;
    width: var(--sidebar-width);
    background: var(--color-bg-secondary);
    border-right: 1px solid var(--color-border);
    overflow-y: auto;
    padding: 1rem 0;
  }

  .sidebar-group {
    margin-bottom: 0.5rem;
  }

  .sidebar-category {
    padding: 0.5rem 1.25rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--cat-color);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sidebar-category-ko {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: none;
  }

  .sidebar ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 1.25rem 0.4rem 1.75rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    border-left: 3px solid transparent;
    transition: all 0.15s;
  }

  .sidebar-link:hover {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.03);
  }

  .sidebar-link.active {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.05);
    border-left-color: var(--cat-color);
    font-weight: 500;
  }

  .ts-only {
    font-size: 0.65rem;
    background: var(--color-border);
    color: var(--color-text-muted);
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    font-weight: 500;
  }

  .content {
    margin-left: var(--sidebar-width);
    flex: 1;
    padding: 2rem 3rem;
    max-width: 960px;
  }

  @media (max-width: 768px) {
    .sidebar { display: none; }
    .content { margin-left: 0; padding: 1.5rem 1rem; }
    .header-sub { display: none; }
  }
</style>
